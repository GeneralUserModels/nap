<style>
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .hero__title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .hero__subtitle {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .hero__authors {
    font-size: var(--fs-md);
    margin-bottom: var(--space-md);
    color: var(--color-text);
    opacity: 0.85;
  }

  .hero__authors sup {
    font-size: 0.7em;
    margin-left: 1px;
  }

  .hero__affiliations {
    font-size: var(--fs-sm);
    margin-bottom: var(--space-lg);
    color: var(--color-text);
    opacity: 0.6;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
