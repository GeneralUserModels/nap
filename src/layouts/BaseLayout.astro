---
import '../styles/global.css';
const { title = 'NAP — Next-Action Prediction' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="NAP records user screen activity, labels it into action descriptions, and trains LLMs to predict next user actions." />

  <!-- OG Tags -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content="A system that records user screen activity, labels it into action descriptions, and trains LLMs to predict next user actions." />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preload" href={`${base}fonts/PlayfairDisplay-Bold.woff2`} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${base}fonts/Inter-Regular.woff2`} as="font" type="font/woff2" crossorigin />
  <Fragment set:html={`<style>
    @font-face {
      font-family: 'Playfair Display';
      src: url('${base}fonts/PlayfairDisplay-Bold.woff2') format('woff2');
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Inter';
      src: url('${base}fonts/Inter-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Inter';
      src: url('${base}fonts/Inter-Medium.woff2') format('woff2');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Inter';
      src: url('${base}fonts/Inter-SemiBold.woff2') format('woff2');
      font-weight: 600;
      font-style: normal;
      font-display: swap;
    }
  </style>`} />

</head>
<body>
  <main>
    <slot />
  </main>

  <script src="../scripts/animations.js"></script>
</body>
</html>
